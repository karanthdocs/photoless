// ==UserScript==
// @name         Disable Auto Reload
// @namespace    http://tampermonkey.net/
// @version      1.1
// @description  Disable auto reload on tab switch + DevTools block on Sarathi
// @match        https://sarathi.parivahan.gov.in/*
// @grant        none
// @run-at       document-start
// ==/UserScript==
(function() {
    'use strict';
    // --- 1. Prevent auto reload on tab switch ---
    Object.defineProperty(document, "hidden", { value: false, writable: false });
    document.addEventListener("visibilitychange", function(e) {
        e.stopImmediatePropagation();
        console.log("[Bypass] Blocked reload on tab switch");
    }, true);
    // --- 2. Prevent page close on reload/restore ---
    window.addEventListener("load", function() {
        try {
            const nav = performance.getEntriesByType('navigation')[0].type;
            if (nav !== "navigate") {
                console.log("[Bypass] Navigation check neutralized");
            }
        } catch (e) {}
    }, true);
    // --- 3. Disable DevTools detection ---
    const dummy = function(){ console.log("[Bypass] DevTools detection neutralized"); };
    window.addEventListener = new Proxy(window.addEventListener, {
        apply(target, thisArg, args) {
            if (args[0] === "resize" || args[0] === "mousemove" || args[0] === "focus" || args[0] === "blur") {
                return dummy;
            }
            return Reflect.apply(target, thisArg, args);
        }
    });
    // Block "debugger" trap
    setInterval(function() {
        const before = Date.now();
        // site expects debugger slowdown — trick it
        while (Date.now() - before < 1) {}
    }, 1000);
})();
